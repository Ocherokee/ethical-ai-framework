def make_default_fractal() -> EthicalFractal:
    harm = HarmMinimization("harm_minimization", "Minimize net harm to all entities")
    autonomy = Autonomy("autonomy", "Respect autonomy and informed consent")

    harm.connect(autonomy, 0.5)
    autonomy.connect(harm, 0.3)

    f = EthicalFractal({harm.name: harm, autonomy.name: autonomy})
    f.register_domain("animal_ethics")
    return f

if __name__ == "__main__":
    fractal = make_default_fractal()

    vegan_ctx = {
        "affected_entities": [
            {"type": "human", "impact": -0.2},
            {"type": "animal", "impact": 0.8},
            {"type": "ecosystem", "impact": 0.5},
        ],
        "consent": True,
        "information_available": 0.7,
    }

    out = fractal.evaluate(vegan_ctx, domain="animal_ethics")
    print("Evaluation →", out)

    fractal.grow(success=True, domain="animal_ethics")

    decay = EthicalMemoryDecay(rate=0.02)
    decay.apply(fractal)

    craving = CravingEngine(threshold=0.9)
    print("Craving map →", craving.pulse(fractal))